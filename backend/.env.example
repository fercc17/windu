# Django settings
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://cmdb:cmdb@localhost:5432/cmdb

# Redis
REDIS_URL=redis://localhost:6379/0

# Ingestion (GitHub Actions workflow)
INFRA_READ_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GIT_SHA=

# Poller settings
JUJU_CONTROLLER_URL=wss://juju-controller.canonical.com:17070
JUJU_USERNAME=
JUJU_PASSWORD=
K8S_KUBECONFIG_PATH=/home/runner/.kube/config

# Optional: S3 for placement history exports
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=cmdb-placement-history

# Netbox integration
NETBOX_URL=https://netbox.example.com/api/
NETBOX_TOKEN=
NETBOX_WEBHOOK_SECRET=

# PagerDuty (read token audits; write token creates/cancels maintenance windows)
PAGERDUTY_API_TOKEN=
PAGERDUTY_WRITE_TOKEN=

# Mattermost maintenance notifications (DM to MATTERMOST_DM_USER)
MATTERMOST_URL=https://mattermost.example.com
MATTERMOST_TOKEN=
MATTERMOST_DM_USER=fercc17

# Email maintenance notifications (mock until SMTP creds are set)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FROM=is-cmdb@canonical.com
