# windu — consolidated DEVELOPMENT tokens. DO NOT COMMIT (gitignored).
# Production uses Juju secrets, NOT this file.
# Consolidated from is-cmdb, jira-analysis, and standup-dashboard.
# NOTE: keep comments on their own lines — inline '# ...' is NOT stripped
#       by django-environ and would corrupt the value.


# ---- GitHub ----
# PR/repo reads (standup) + infra ingestion (is-cmdb)
GITHUB_TOKEN=
# is-cmdb infra ingestion (legacy name)
INFRA_READ_TOKEN=

# ---- Jira (read-only) ----
JIRA_BASE_URL=
JIRA_EMAIL=
# covers issues, changelog, worklogs
JIRA_API_TOKEN=
# alias read by vendored isreq_dashboard
ISREQ_JIRA_BASE_URL=
ISREQ_JIRA_EMAIL=
ISREQ_JIRA_API_TOKEN=

# ---- PagerDuty ----
# read token (audits / analytics)
PAGERDUTY_API_TOKEN=
# create/cancel maintenance windows
PAGERDUTY_WRITE_TOKEN=
# weekend on-call iCal feed (standup)
PAGERDUTY_ICAL_URL=
# alias read by vendored isreq_dashboard
PD_API_TOKEN=
# comma-separated PagerDuty team ids
PD_TEAM_IDS=

# ---- NetBox ----
NETBOX_URL=
NETBOX_TOKEN=
NETBOX_WEBHOOK_SECRET=

# ---- Juju ----
JUJU_CONTROLLER_URL=
JUJU_USERNAME=
JUJU_PASSWORD=

# ---- AWS / S3 (placement-history exports) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# ---- Mattermost (maintenance notifications) ----
MATTERMOST_URL=
MATTERMOST_TOKEN=
MATTERMOST_DM_USER=

# ---- Email / SMTP (maintenance notifications) ----
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FROM=

# ---- Tempo (worklogs, optional) ----
TEMPO_TOKEN=
